---
// src/components/Terminal.astro
---

<div class="terminal animate-fade-in-up">
    <div class="terminal-dots">
        <div class="terminal-dot red"></div>
        <div class="terminal-dot yellow"></div>
        <div class="terminal-dot green"></div>
    </div>
    <div class="terminal-content">
        <pre><code id="terminal-code"></code></pre>
    </div>
</div>
<button class="try-demo-btn animate-fade-in-up animate-delay-1" id="replay-demo-btn" aria-label="Replay terminal animation">Run Demo Again</button>

<style>
    .terminal {
        background: #1a1a1a;
        border-radius: 8px;
        padding: 24px;
        margin: 24px 0 16px 0;
        overflow-x: auto;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    /* Dark mode enhancements */
    :global(html[data-theme='dark']) .terminal {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        border: 1px solid var(--sl-color-hairline-shade);
    }

    .terminal:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(59, 130, 246, 0.15);
    }

    .terminal::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 32px;
        background: #2a2a2a;
        border-radius: 8px 8px 0 0;
        border-bottom: 1px solid #333;
    }

    .terminal-dots {
        position: absolute;
        top: 12px;
        left: 16px;
        display: flex;
        gap: 8px;
        z-index: 1;
    }

    .terminal-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .terminal-dot.red { background: #ff5f56; }
    .terminal-dot.yellow { background: #ffbd2e; }
    .terminal-dot.green { background: #27c93f; }

    .terminal-content {
        margin-top: 32px;
    }

    .terminal pre {
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        box-shadow: none;
    }

    .terminal code {
        font-family: var(--sl-font-mono) !important;
        font-size: 0.85rem;
        color: #e5e5e5 !important;
        background: transparent !important;
        line-height: 1.8;
        display: block;
        white-space: pre-wrap;
        border: none;
        padding: 0;
    }

    .terminal .prompt { color: #888; }
    .terminal .cmd { color: #fff; }
    .terminal .out { color: #888; }
    .terminal .hl { 
        color: #7dd3fc;
        font-weight: 500;
    }
    .terminal .ok { 
        color: #86efac;
    }

    @media (prefers-reduced-motion: no-preference) {
        .terminal .ok {
            animation: pulse 1.5s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
    }

    .terminal .cursor {
        display: inline-block;
        width: 8px;
        height: 15px;
        background-color: #e5e5e5;
        vertical-align: middle;
        margin-left: 6px;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    /* Button styles */
    .try-demo-btn {
        display: inline-block;
        padding: 10px 20px;
        background: #3b82f6;
        color: white;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        border: none;
        transition: all 0.3s ease;
    }

    .try-demo-btn:hover {
        background: #2563eb;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .try-demo-btn:active {
        transform: translateY(0);
    }
</style>

<script>
    function initializeTerminalAnimation() {
        const container = document.getElementById('terminal-code');
        const replayBtn = document.getElementById('replay-demo-btn');
        if (!container || !replayBtn) return;
        
        let timeoutIds: number[] = [];
        let isAnimating = false;

        const sequence = [
            { type: 'cmd', txt: 'ceres harvest https://dati.comune.milano.it', postDelay: 800 },
            { type: 'out', txt: 'Fetching package list...', postDelay: 1200 },
            { type: 'out', txt: 'Found 2575 datasets', postDelay: 400 },
            { type: 'ok',  txt: '✓ Harvesting complete: 2575 indexed', postDelay: 1000 },
            { type: 'empty', postDelay: 200 },
            { type: 'cmd', txt: 'ceres search "trasporto pubblico"', postDelay: 600 },
            { type: 'empty', postDelay: 100 },
            { type: 'hl',  txt: '78%  TPL - Percorsi linee di superficie', postDelay: 150 },
            { type: 'hl',  txt: '76%  TPL - Fermate linee di superficie', postDelay: 150 },
            { type: 'hl',  txt: '72%  Mobilità: flussi veicolari', postDelay: 500 }
        ];

        function runAnimation() {
            if (isAnimating) return;
            isAnimating = true;
            
            // Clear current timeouts
            timeoutIds.forEach(clearTimeout);
            timeoutIds = [];
            
            container.innerHTML = '';
            
            let delayTime = 0;
            
            for (let i = 0; i < sequence.length; i++) {
                const step = sequence[i];
                
                const currentDelay = delayTime;
                
                const t1 = window.setTimeout(() => {
                    if (step.type === 'empty') {
                        container.innerHTML += '\n';
                    } else if (step.type === 'cmd') {
                        const lineId = 'line-' + i;
                        container.innerHTML += `<span class="prompt">$</span> <span class="cmd" id="${lineId}"></span><span class="cursor" id="cursor-${i}"></span>\n`;
                        
                        const lineEl = document.getElementById(lineId);
                        const cursorEl = document.getElementById(`cursor-${i}`);
                        
                        // Typewriter effect for command
                        let charIdx = 0;
                        function typeChar() {
                            if (charIdx < step.txt.length && lineEl) {
                                lineEl.textContent += step.txt.charAt(charIdx);
                                charIdx++;
                                // Variable typing speed between 20ms and 70ms
                                const typeSpeed = Math.random() * 50 + 20;
                                const tx = window.setTimeout(typeChar, typeSpeed);
                                timeoutIds.push(tx);
                            } else {
                                // Done typing command, pause and remove cursor
                                const ty = window.setTimeout(() => {
                                    if (cursorEl) cursorEl.style.display = 'none';
                                    if (i === sequence.length - 1) isAnimating = false;
                                }, 300);
                                timeoutIds.push(ty);
                            }
                        }
                        
                        // Initial pause before typing starts
                        const tz = window.setTimeout(typeChar, 300);
                        timeoutIds.push(tz);
                        
                    } else {
                        // Instant output rendering
                        let html = '';
                        if (step.type === 'hl') {
                            const hlPart = step.txt.substring(0, 3);
                            const restPart = step.txt.substring(3);
                            html = `<span class="hl">${hlPart}</span><span class="out">${restPart}</span>\n`;
                        } else if (step.type === 'ok') {
                            const okPart = step.txt.substring(0, 1);
                            const restPart = step.txt.substring(1);
                            html = `<span class="ok">${okPart}</span><span class="out">${restPart}</span>\n`;
                        } else {
                            html = `<span class="out">${step.txt}</span>\n`;
                        }
                        
                        container.innerHTML += html;
                        
                        if (i === sequence.length - 1) isAnimating = false;
                    }
                }, currentDelay);
                
                timeoutIds.push(t1);
                
                // Add delay for next line scheduling
                if (step.type === 'cmd') {
                    // estimated typing time (avg 45ms per char) + initial pause + post pause
                    delayTime += (step.txt.length * 45) + 300 + step.postDelay;
                } else {
                    delayTime += step.postDelay;
                }
            }
        }

        runAnimation();

        replayBtn.addEventListener('click', () => {
             // force stop any ongoing and rerun
             timeoutIds.forEach(clearTimeout);
             timeoutIds = [];
             isAnimating = false;
             runAnimation();
        });
    }

    // Initialize animation on normal page load 
    // and correctly hook into Astro's View Transitions if enabled later
    document.addEventListener('astro:page-load', initializeTerminalAnimation);
    
    // Fallback for standard load if view transitions aren't processing
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initializeTerminalAnimation();
    } else {
        document.addEventListener('DOMContentLoaded', initializeTerminalAnimation);
    }
</script>
